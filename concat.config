# File: ./concat.config
# ==============================================================================
# BEDROCK LANGUAGE APP - RECURSIVE CONCATENATION CONFIGURATION
# ==============================================================================

# Target output file for LLM context aggregation
OUTPUT_FILE="a.txt"

# --- RECURSIVE SEARCH EXCLUDES ---
# Files and directories to completely ignore during the initial find sweep
EXCLUDES=(
    "*/node_modules/*"
    "*/dist/*"
    "*/.git/*"
    "*/.vite/*"
    "*/coverage/*"
    "*/.venv/*"
    "*/android/*"
    "./.env"
    "*/ios/*"
)

# --- PRUNING SPECIFICS with EXCEPTIONS ---
# Folders we want to completely bypass unless explicit files within them are whitelisted.
# This prevents context bloat from massive directories while retaining critical reference files.


PRUNES=(
    "./node_modules"
    "./dist"
    "./.git"
    "./.vite"
    "./.idea"
    "./.vscode"
    "./coverage"
    "./.venv"
    ".eslintcache"
    "./current_response.json"
)

# --- WEB & PLATFORM-SPECIFIC PRUNING ---
WEB_PRUNES=(
    # Credentials and Secrets (Safety)
    "./bedrock-6d04a-firebase-adminsdk-fbsvc-38ae97cff1.json"
    "*.pem"
    "*.key"
    "*.jks"
    "*.keystore"

    # High-Volume Static Media (Avoid binary dump in context)
    "./src/server/assets"
    "*.png"
    "*.jpg"
    "*.jpeg"
    "*.gif"
    "*.svg"
    "*.ico"
    "*.webp"
    "*.mp4"
    "*.mov"
    "*.pdf"
    "*.ttf"
    "*.woff"
    "*.woff2"

    # Playwright & Browser Unit Test Artifacts
    "./test-results"
    "./playwright-report"

    # Terraform & Infrastructure Binaries
    "./infra/hetzner/.terraform"
    "*.tfstate"
    "*.tfstate.backup"

    # Native Platform Targets
    "./android"
    "./ios"

    # Package Lock Files & Lock Binaries
    "./bun.lock"
    "./bun.lockb"
    "./package-lock.json"
    "./pnpm-lock.yaml"
    "./yarn.lock"

)

# --- ROOT FILE SEARCH SCHEME ---
# Scan these root-level files specifically for workspace setups
ROOT_EXTENSIONS=(
    "*.json"
    "*.ts"
    "*.js"
    "*.config"
    "*.yaml"
    "*.yml"
    "*.nix"
    "*.sh"
    "*.md"
)

ROOT_EXCLUDES=(
    "./current_response.json"
    "./a.txt"
    "./context_testing.txt"
)
